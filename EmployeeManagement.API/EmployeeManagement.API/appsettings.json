{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DatabaseProvider": "PostgreSQL",

  "ConnectionStrings": {
    "SqlServer": "Server=(localdb)\\MSSQLLocalDB;Database=EmployeeManagementDB;Integrated Security=True;TrustServerCertificate=True;",
    "PostgreSQL": "Host=localhost;Port=5433;Database=EmployeeManagementDB;Username=postgres;Password=postgres;",
    "MySQL": "Server=localhost;Port=3306;Database=EmployeeManagementDB;Uid=root;Pwd=YourPassword;"
  },

  "Jwt": {
    "Key": "EmployeeManagementSuperSecretKey@2024!XYZ",
    "Issuer": "EmployeeManagement.API",
    "Audience": "EmployeeManagement.Client",
    "ExpirationMinutes": 60
  },

  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:4200", "https://your-azure-app.azurewebsites.net" ]
  }
}
